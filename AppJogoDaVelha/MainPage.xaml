<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppJogoDaVelha.MainPage">
    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,1" EndPoint="1,0">
            <GradientStop Color="Purple" Offset="0.3"/>
            <GradientStop Color="Red" Offset="1.1"/>
        </LinearGradientBrush>
    </ContentPage.Background>

    <ContentPage.Resources>
        <Style TargetType="Button">
            <Setter Property="BackgroundColor" Value="Transparent" />
            <Setter Property="TextColor" Value="White"/>
            <Setter Property="FontSize" Value="80"/>
            <Setter Property="BorderColor" Value="Transparent"/>
        </Style>
    </ContentPage.Resources>

    <ContentPage.Content>
        <Grid x:Name="game" RowDefinitions="*, *, *, *, *" ColumnDefinitions="*, *, *" ColumnSpacing="5" RowSpacing="5" Margin="15">
            <Label Grid.ColumnSpan="3" Grid.Row="0" Grid.Column="0" 
                   Text="JOGO DA VELHA" FontSize="50" 
                   TextColor="White" FontAttributes="Bold"
                   HorizontalTextAlignment="Center" VerticalTextAlignment="Center" FontFamily="" />

            <Button x:Name="btn10" Grid.Row="1" Grid.Column="0" Clicked="Button_Clicked"/>
            <Button x:Name="btn11" Grid.Row="1" Grid.Column="1" Clicked="Button_Clicked"/>
            <Button x:Name="btn12" Grid.Row="1" Grid.Column="2" Clicked="Button_Clicked"/>

            <Button x:Name="btn20" Grid.Row="2" Grid.Column="0" Clicked="Button_Clicked"/>
            <Button x:Name="btn21" Grid.Row="2" Grid.Column="1" Clicked="Button_Clicked"/>
            <Button x:Name="btn22" Grid.Row="2" Grid.Column="2" Clicked="Button_Clicked"/>

            <Button x:Name="btn30" Grid.Row="3" Grid.Column="0" Clicked="Button_Clicked"/>
            <Button x:Name="btn31" Grid.Row="3" Grid.Column="1" Clicked="Button_Clicked"/>
            <Button x:Name="btn32" Grid.Row="3" Grid.Column="2" Clicked="Button_Clicked"/>

            <BoxView Grid.Row="1" Grid.RowSpan="3" Grid.Column="1"
             WidthRequest="3"
             HorizontalOptions="Start"
             Color="White"/>

            <BoxView Grid.Row="1" Grid.RowSpan="3" Grid.Column="2"
             WidthRequest="3"
             HorizontalOptions="Start"
             Color="White"/>

            <BoxView Grid.Row="2" Grid.ColumnSpan="3"
             HeightRequest="3"
             VerticalOptions="Start"
             Color="White"/>

            <BoxView Grid.Row="3" Grid.ColumnSpan="3"
             HeightRequest="3"
             VerticalOptions="Start"
             Color="White"/>

            <Label x:Name="lblWins" Text="X: 0 | O: 0" 
                   Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3" 
                   FontSize="20" TextColor="White" VerticalOptions="Center" HorizontalOptions="Center"
                   FontAttributes="Bold" />
        </Grid>
    </ContentPage.Content>
</ContentPage>
